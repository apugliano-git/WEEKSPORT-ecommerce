# ============================================================
# WEEKSPORT — Variables de Entorno (Template)
# ============================================================
# Copiá este archivo como .env.local para desarrollo local:
#   cp .env.example .env.local
#
# NUNCA subas .env.local al repositorio.
# En Vercel: configurar estas variables en Settings > Environment Variables
# ============================================================

# --- Supabase ---
# Encontrás estos valores en: supabase.com > tu proyecto > Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="tu-anon-key-publica"

# ⚠️ La service role key NUNCA va en el frontend ni en variables NEXT_PUBLIC_
# Solo usarla en scripts de server-side o migraciones de BD si fuera necesario.
# SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key-secreta"
